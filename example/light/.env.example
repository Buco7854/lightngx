# Copy to .env. Everything has a default, so an empty .env runs fine.
# Full variable reference: https://buco7854.github.io/lightngx/configuration

# Optional: pin the session secret (32+ chars); unset, a generated key
# stored in the data volume is used. Generate: openssl rand -hex 32
LN_SESSION_SECRET=

# Who reaches the UI port. 0.0.0.0 exposes it on the LAN (local HTTP only).
# UI_BIND=127.0.0.1

# Pre-seed the first admin to skip the setup page.
# Hash: docker run --rm -i ghcr.io/buco7854/lightngx:latest hash
# Double every "$" as "$$" so compose does not expand it.
# LN_ADMIN_USER=
# LN_ADMIN_PASSWORD_HASH=
